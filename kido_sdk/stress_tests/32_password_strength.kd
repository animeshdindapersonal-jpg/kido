# 32. Password Strength Checker
print "=== Password Strength Checker ==="
list passwords = "hello" "Hello123" "HelloWorld2024"
list strengths = "Weak" "Medium" "Strong"
list scores = 1 3 5

repeat length passwords times as i
    remember pwd = passwords at i
    remember score = scores at i
    remember strength = strengths at i
    remember pwd_len = length pwd
    print pwd "(len:" pwd_len ") -" strength "(" score "/5)"
