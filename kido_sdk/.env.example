# KIDO runtime limits (optional — defaults are production-safe)
# Copy to .env only if your installer loads env files; otherwise export in shell.

# Max nested user-function calls (default 500)
KIDO_MAX_RECURSION=500

# Max loop iterations across the whole program (default 1000000)
KIDO_MAX_LOOP_ITERS=1000000

# Max seconds for a single `wait` (default 60)
KIDO_MAX_WAIT_SECONDS=60

# Max exponent for `to the power` (default 10000)
KIDO_MAX_POWER_EXPONENT=10000

# Max file size for read/write (bytes, default 10485760 = 10MB)
KIDO_MAX_FILE_BYTES=10485760

# Max .kd source size (bytes, default 2097152 = 2MB)
KIDO_MAX_SOURCE_BYTES=2097152

# Path sandbox: 1 = only allow file I/O inside project folder (default)
# Set to 0 only for fully trusted programs on a locked-down machine
KIDO_SANDBOX=1

# Show internal Python traces on unexpected errors (default off)
KIDO_DEBUG=0
