fun contains items val
    remember i = 1
    repeat length items times
        if items[i] is val
            return 1
        i = i + 1
    return 0

list numbers = 5 12 8 23 17
remember found = contains numbers 8
if found is 1
    print "f020: list contains 8"
else
    print "f020: list does not contain 8"

remember found2 = contains numbers 99
if found2 is 1
    print "f020: list contains 99"
else
    print "f020: list does not contain 99"



