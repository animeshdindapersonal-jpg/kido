fun isEven n
    remember remainder = n - floor(n / 2) * 2
    if remainder is 0
        return 1
    return 0

remember num = 10
remember even = isEven num
if even is 1
    print "f007: 10 is even"
else
    print "f007: 10 is odd"

remember num2 = 7
remember even2 = isEven num2
if even2 is 1
    print "f007: 7 is even"
else
    print "f007: 7 is odd"



